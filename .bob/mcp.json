{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
      },
      "disabled": false,
      "alwaysAllow": [
        "search_repositories",
        "get_issue",
        "add_issue_comment",
        "get_file_contents",
        "create_or_update_file",
        "create_pull_request",
        "create_branch",
        "update_issue",
        "list_issues",
        "search_issues",
        "push_files",
        "list_commits"
      ]
    }
  }
}